# Copy this file to `.env` and fill in real values before running docker compose.
# All defaults below are placeholders — do NOT use them in production.

# --- PostgreSQL ---
POSTGRES_USER=athena
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=athena

# --- Backend ---
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-me-with-at-least-32-random-characters-please

# Host ports. Both services bind to every host interface (0.0.0.0) so other
# devices on your LAN can reach the app at http://<host-ip>:${FRONTEND_PORT};
# see SECURITY.md ("Threat model") before exposing beyond the host. To keep
# access local, restrict with a host firewall, or edit docker-compose.yml
# and prefix the ports with "127.0.0.1:" (e.g. "127.0.0.1:8000:80").
# The frontend proxies API calls to the backend via nginx.
# Avoid 6000 / 6666 / 6665-6669 / 6697 — Chrome blocks them as ERR_UNSAFE_PORT.
FRONTEND_PORT=8000
BACKEND_PORT=8001

# Set to true when running behind an HTTPS-terminating reverse proxy. On a
# plain-HTTP LAN deployment, leave false — otherwise the session cookie is
# rejected by the browser and login silently fails.
COOKIE_SECURE=false

# Bearer token for /metrics. When set (>= 16 chars), the endpoint requires
# `Authorization: Bearer <token>`; when unset, /metrics is public and a
# startup warning is logged. Generate with `openssl rand -hex 32`.
# METRICS_TOKEN=replace-me-with-at-least-16-random-characters
