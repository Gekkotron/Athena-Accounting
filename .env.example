# Copy this file to `.env` and fill in real values before running docker compose.
# All defaults below are placeholders — do NOT use them in production.

# --- PostgreSQL ---
POSTGRES_USER=athena
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=athena

# --- Backend ---
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-me-with-at-least-32-random-characters-please

# Host ports. Both services bind to 127.0.0.1 only — never exposed beyond
# the host. The frontend proxies API calls to the backend via nginx.
# Avoid 6000 / 6666 / 6665-6669 / 6697 — Chrome blocks them as ERR_UNSAFE_PORT.
FRONTEND_PORT=8000
BACKEND_PORT=8001

# Set to true when running behind an HTTPS-terminating reverse proxy. On a
# plain-HTTP LAN deployment, leave false — otherwise the session cookie is
# rejected by the browser and login silently fails.
COOKIE_SECURE=false
