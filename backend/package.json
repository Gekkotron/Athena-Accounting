{
  "name": "athena-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "bash scripts/test-db.sh"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/session": "^11.0.1",
    "@napi-rs/canvas": "^0.1.55",
    "@node-rs/argon2": "^2.0.2",
    "csv-parse": "^5.5.6",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "iconv-lite": "^0.6.3",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "form-data": "^4.0.6",
    "pdfkit": "^0.15.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
