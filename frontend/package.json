{
  "name": "athena-frontend",
  "version": "1.0.0-desktop-beta1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "VITE_DEMO=1 tsc -b && VITE_DEMO=1 vite build",
